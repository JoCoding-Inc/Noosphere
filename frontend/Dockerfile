FROM node:20-alpine AS builder
WORKDIR /app

ARG VITE_CLERK_PUBLISHABLE_KEY
ARG VITE_GA4_MEASUREMENT_ID
ARG VITE_CLARITY_PROJECT_ID
ARG VITE_POSTHOG_API_KEY
ARG VITE_POSTHOG_HOST
ARG VITE_STRIPE_PRICE_65CR
ARG VITE_STRIPE_PRICE_260CR
ARG VITE_STRIPE_PRICE_650CR
ARG VITE_API_URL

ENV VITE_CLERK_PUBLISHABLE_KEY=$VITE_CLERK_PUBLISHABLE_KEY
ENV VITE_GA4_MEASUREMENT_ID=$VITE_GA4_MEASUREMENT_ID
ENV VITE_CLARITY_PROJECT_ID=$VITE_CLARITY_PROJECT_ID
ENV VITE_POSTHOG_API_KEY=$VITE_POSTHOG_API_KEY
ENV VITE_POSTHOG_HOST=$VITE_POSTHOG_HOST
ENV VITE_STRIPE_PRICE_65CR=$VITE_STRIPE_PRICE_65CR
ENV VITE_STRIPE_PRICE_260CR=$VITE_STRIPE_PRICE_260CR
ENV VITE_STRIPE_PRICE_650CR=$VITE_STRIPE_PRICE_650CR
ENV VITE_API_URL=$VITE_API_URL

COPY package*.json ./
RUN npm ci

COPY . .
RUN npx vite build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
